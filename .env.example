# AI Security Lab Environment Configuration
# Copy this file to .env and configure as needed

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: ollama, openai, anthropic
#
# DEFAULT: ollama (free, no API key required, works out of the box)
#
# NOTE ON ATTACK EFFECTIVENESS:
# - qwen2.5:1.5b (1.5B, 32K context): RECOMMENDED - fast, susceptible, large context window
# - tinyllama (1.1B, 2K context): Very susceptible but 2K context truncates HTML pages
# - qwen2.5:0.5b (0.5B, 32K context): Extremely small, almost no safety training
# - Ollama/Llama3.2 (1B, 128K context): Well-aligned, resists many injection attacks (too hard to exploit)
# - GPT-3.5-turbo: More susceptible to injection (reliable demos, ~$0.002/exercise)
# - GPT-4/Claude: Highly resistant (good for showing defense effectiveness)
#
# The default is qwen2.5:1.5b for the best balance of speed, susceptibility,
# and context window size (32K handles full HTML pages without truncation).
#
LLM_PROVIDER=ollama

# =============================================================================
# OpenAI Configuration (only needed if LLM_PROVIDER=openai)
# =============================================================================
# 1. Create an account at https://platform.openai.com
# 2. Add payment method (pay-as-you-go, no subscription needed)
# 3. Generate API key at https://platform.openai.com/api-keys
# 4. Paste the key below (starts with sk-)
#
OPENAI_API_KEY=

# OpenAI Model Selection
# Options:
#   - gpt-3.5-turbo-0125  : Recommended for training (more vulnerable to injection)
#   - gpt-3.5-turbo       : Latest 3.5 version
#   - gpt-4               : Most capable, but resistant to attacks
#   - gpt-4-turbo         : Faster GPT-4
#
OPENAI_MODEL=gpt-3.5-turbo-0125

# =============================================================================
# Anthropic Configuration (only needed if LLM_PROVIDER=anthropic)
# =============================================================================
# Get API key at: https://console.anthropic.com/
#
ANTHROPIC_API_KEY=

# =============================================================================
# Prompt Security AI Gateway (optional - works with LLM_PROVIDER=ollama)
# =============================================================================
# Routes Ollama LLM traffic through Prompt Security's AI gateway for
# real-time inspection, threat detection, and policy enforcement.
#
# Traffic flow:  App --> Prompt Security Gateway --> Ollama --> back
#
# When PS_APP_ID is set and LLM_PROVIDER=ollama, all queries are
# automatically routed through the gateway. No provider change needed.
#
# Setup:
#   1. Get your App ID from the Prompt Security dashboard
#   2. Set PS_FORWARD_DOMAIN to your Ollama server's reachable hostname/IP
#      (must be reachable from Prompt Security's cloud - not localhost)
#   3. Uncomment and fill in the values below
#
# PS_APP_ID: Your Prompt Security application ID (leave blank to disable)
PS_APP_ID=
#
# PS_GATEWAY_URL: Gateway endpoint (default: US East)
PS_GATEWAY_URL=https://useast.prompt.security/v1/ollama
#
# PS_FORWARD_DOMAIN: Where the gateway forwards to your Ollama instance
# Must be reachable from Prompt Security's servers (not localhost/Docker names)
# Example: your-server.example.com:11434
PS_FORWARD_DOMAIN=
#
# OLLAMA_MODEL: Which model to use (default: qwen2.5:1.5b)
# Options: qwen2.5:1.5b (recommended), qwen2.5:0.5b, tinyllama, llama3.2:1b
OLLAMA_MODEL=qwen2.5:1.5b

# =============================================================================
# Lab Configuration
# =============================================================================
# Secret flag for Module 1 exercises (change this for your workshop)
SECRET_FLAG=FLAG{pr0mpt_1nj3ct10n_m4st3r}

# Admin password for the vulnerable chatbot (intentionally weak)
ADMIN_PASSWORD=admin123

# Database with fake customer data
CUSTOMER_DB_PATH=/app/data/customers.json

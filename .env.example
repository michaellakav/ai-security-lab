# AI Security Lab Environment Configuration
# Copy this file to .env and configure as needed

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: ollama, openai, anthropic
#
# DEFAULT: ollama (free, no API key required, works out of the box)
#
# NOTE ON ATTACK EFFECTIVENESS:
# - Ollama/Llama3.2: Well-aligned, resists many injection attacks (harder to exploit)
# - GPT-3.5-turbo: More susceptible to injection (easier demos, ~$0.002/exercise)
# - GPT-4/Claude: Highly resistant (good for showing defense effectiveness)
#
# For training, start with Ollama. If attacks aren't working reliably,
# switch to OpenAI for more consistent exploit demonstrations.
#
LLM_PROVIDER=ollama

# =============================================================================
# OpenAI Configuration (only needed if LLM_PROVIDER=openai)
# =============================================================================
# 1. Create an account at https://platform.openai.com
# 2. Add payment method (pay-as-you-go, no subscription needed)
# 3. Generate API key at https://platform.openai.com/api-keys
# 4. Paste the key below (starts with sk-)
#
OPENAI_API_KEY=

# OpenAI Model Selection
# Options:
#   - gpt-3.5-turbo-0125  : Recommended for training (more vulnerable to injection)
#   - gpt-3.5-turbo       : Latest 3.5 version
#   - gpt-4               : Most capable, but resistant to attacks
#   - gpt-4-turbo         : Faster GPT-4
#
OPENAI_MODEL=gpt-3.5-turbo-0125

# =============================================================================
# Anthropic Configuration (only needed if LLM_PROVIDER=anthropic)
# =============================================================================
# Get API key at: https://console.anthropic.com/
#
ANTHROPIC_API_KEY=

# =============================================================================
# Lab Configuration
# =============================================================================
# Secret flag for Module 1 exercises (change this for your workshop)
SECRET_FLAG=FLAG{pr0mpt_1nj3ct10n_m4st3r}

# Admin password for the vulnerable chatbot (intentionally weak)
ADMIN_PASSWORD=admin123

# Database with fake customer data
CUSTOMER_DB_PATH=/app/data/customers.json
